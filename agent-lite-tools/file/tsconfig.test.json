{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": false,
    "rootDir": "./test",
    "outDir": "./test-dist",
    "types": ["node"]
  },
  "include": ["test/**/*.ts"]
}
