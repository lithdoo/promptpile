{
  "name": "promptpile-react",
  "version": "1.0.0-beta.0",
  "description": "在 promptpile CLI 之上的 agent 编排（子进程调用 CLI；`-i` 写入 user 消息时依赖 workspace `promptpile` 包内的 file-handler）",
  "main": "dist/index.js",
  "bin": {
    "promptpile-react": "dist/index.js"
  },
  "keywords": [
    "promptpile-react",
    "promptpile",
    "react",
    "command-line"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "npm run build && node test/resolve-react-config.cjs"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@types/node": "^25.5.2",
    "commander": "^14.0.3",
    "promptpile": "1.0.0-beta.0",
    "typescript": "~5.9.3"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
