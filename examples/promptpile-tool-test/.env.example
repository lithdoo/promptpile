# agent-lite web 工具的可选配置；promptpile 本身不读取此文件。
AI_MODEL=deepseek-chat
AI_API_KEY=
AI_API_BASE_URL=https://api.deepseek.com/v1
DEFAULT_DIRECTORY=./messages
QUIET=false

# SearXNG（可选）
# SEARXNG_BASE_URL=http://127.0.0.1:8080
# 逗号分隔；不写则用脚本内置默认（google,bing,brave,duckduckgo）。须在实例 settings.yml 里启用对应引擎。
# SEARXNG_DEFAULT_ENGINES=google,bing,brave
